<!doctype html>
<html lang="en" class="h-full">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#0b1020" media="(prefers-color-scheme: dark)" />
  <meta name="theme-color" content="#f5f7fb" media="(prefers-color-scheme: light)" />
  <title><%= typeof title !== 'undefined' ? title : 'public-mail' %></title>
  <script>
    (function () {
      try {
        var t = localStorage.getItem('theme');
        if (!t) t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.dataset.theme = t;
        if (t === 'dark') document.documentElement.classList.add('dark');
      } catch (e) {}
    })();
  </script>
  <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            ink: { 50:'#f5f7fb', 100:'#eef1f8', 200:'#dde3ef', 300:'#bcc6da', 400:'#8a96b3', 500:'#5b6886', 600:'#3f4a66', 700:'#2a3349', 800:'#1a2236', 900:'#0f1626', 950:'#0b1020' },
            brand: { 50:'#eef4ff', 100:'#dce8ff', 200:'#b9d2ff', 300:'#8fb2ff', 400:'#6189ff', 500:'#3f63ff', 600:'#2746ee', 700:'#1f37c4', 800:'#1b2f9a', 900:'#1a2a7a' },
          },
          fontFamily: { sans: ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif'] },
          boxShadow: { glow: '0 0 0 1px rgba(63,99,255,.2), 0 8px 32px -8px rgba(63,99,255,.35)' },
        }
      }
    }
  </script>
  <link rel="preconnect" href="https://rsms.me/" />
  <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
  <link rel="stylesheet" href="/app.css" />
  <script defer src="https://unpkg.com/lucide@latest"></script>
  <script defer src="https://unpkg.com/alpinejs@3.13.10/dist/cdn.min.js"></script>
</head>
<body class="h-full bg-ink-50 text-ink-900 dark:bg-ink-950 dark:text-ink-100 font-sans antialiased"
      x-data="appShell()" x-cloak>

  <!-- Toasts -->
  <div class="fixed z-50 top-3 left-1/2 -translate-x-1/2 flex flex-col gap-2 pointer-events-none" aria-live="polite">
    <template x-for="t in toasts" :key="t.id">
      <div class="pointer-events-auto px-4 py-2 rounded-xl shadow-glow backdrop-blur bg-white/90 dark:bg-ink-800/90 border border-ink-200/50 dark:border-ink-700/50 text-sm flex items-center gap-3 animate-toast">
        <i :data-lucide="t.icon || 'check-circle-2'" class="w-4 h-4 text-brand-500"></i>
        <span x-text="t.msg"></span>
        <button x-show="t.undo" @click="t.undo && t.undo()" class="text-brand-500 hover:underline">Undo</button>
      </div>
    </template>
  </div>

  <div class="h-full flex flex-col">

    <!-- Top bar -->
    <header class="sticky top-0 z-30 backdrop-blur-xl bg-white/70 dark:bg-ink-950/70 border-b border-ink-200/50 dark:border-ink-800/60">
      <div class="flex items-center gap-3 px-3 sm:px-5 h-14">
        <button class="md:hidden p-2 -ml-2 rounded-lg hover:bg-ink-100 dark:hover:bg-ink-800" @click="sidebarOpen = true" aria-label="Open menu">
          <i data-lucide="menu" class="w-5 h-5"></i>
        </button>
        <a href="/" class="flex items-center gap-2 font-bold tracking-tight">
          <span class="w-8 h-8 rounded-xl bg-gradient-to-br from-brand-400 to-brand-700 grid place-items-center text-white shadow-glow">
            <i data-lucide="mail" class="w-4 h-4"></i>
          </span>
          <span class="hidden sm:inline">public<span class="text-brand-500">·</span>mail</span>
        </a>
        <form action="/" method="get" class="flex-1 max-w-2xl mx-auto relative">
          <input type="hidden" name="folder" value="<%= typeof folder !== 'undefined' ? folder : 'inbox' %>" />
          <i data-lucide="search" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-ink-400"></i>
          <input id="searchInput" name="q" value="<%= typeof q !== 'undefined' ? q : '' %>"
                 placeholder="Search mail…  (press / )"
                 class="w-full pl-9 pr-3 h-10 rounded-xl border border-ink-200 dark:border-ink-700 bg-white/80 dark:bg-ink-900/70 focus:ring-2 focus:ring-brand-500/40 focus:border-brand-500 outline-none transition"/>
        </form>
        <button @click="toggleTheme()" class="p-2 rounded-lg hover:bg-ink-100 dark:hover:bg-ink-800" :title="theme === 'dark' ? 'Light mode' : 'Dark mode'">
          <i :data-lucide="theme === 'dark' ? 'sun' : 'moon'" class="w-5 h-5"></i>
        </button>
        <button @click="shortcutsOpen = true" class="hidden sm:inline-flex p-2 rounded-lg hover:bg-ink-100 dark:hover:bg-ink-800" title="Keyboard shortcuts (?)">
          <i data-lucide="keyboard" class="w-5 h-5"></i>
        </button>
      </div>
    </header>

    <!-- Body -->
    <div class="flex-1 flex min-h-0">

      <!-- Sidebar (desktop fixed, mobile drawer) -->
      <aside
        class="hidden md:flex md:flex-col w-64 lg:w-72 shrink-0 border-r border-ink-200/60 dark:border-ink-800/60 bg-white/40 dark:bg-ink-950/40">
        <%- include('partials/sidebar', { sidebar: sidebar, folder: typeof folder !== 'undefined' ? folder : null, label: typeof label !== 'undefined' ? label : null, systemFolders: systemFolders }) %>
      </aside>

      <!-- Mobile drawer -->
      <div x-show="sidebarOpen" x-transition.opacity class="fixed inset-0 z-40 md:hidden" style="display:none">
        <div class="absolute inset-0 bg-black/40" @click="sidebarOpen = false"></div>
        <aside class="absolute inset-y-0 left-0 w-72 max-w-[80%] bg-white dark:bg-ink-950 shadow-2xl flex flex-col"
               x-transition:enter="transition transform duration-200" x-transition:enter-start="-translate-x-full" x-transition:enter-end="translate-x-0">
          <%- include('partials/sidebar', { sidebar: sidebar, folder: typeof folder !== 'undefined' ? folder : null, label: typeof label !== 'undefined' ? label : null, systemFolders: systemFolders }) %>
        </aside>
      </div>

      <main class="flex-1 min-w-0 flex flex-col">
        <%- body %>
      </main>
    </div>
  </div>

  <!-- Shortcuts modal -->
  <div x-show="shortcutsOpen" x-transition.opacity @keydown.escape.window="shortcutsOpen=false" class="fixed inset-0 z-50 grid place-items-center" style="display:none">
    <div class="absolute inset-0 bg-black/50" @click="shortcutsOpen=false"></div>
    <div class="relative w-[92%] max-w-md rounded-2xl bg-white dark:bg-ink-900 border border-ink-200 dark:border-ink-700 p-6 shadow-2xl">
      <h2 class="font-semibold text-lg mb-4 flex items-center gap-2"><i data-lucide="keyboard" class="w-5 h-5"></i> Keyboard shortcuts</h2>
      <dl class="grid grid-cols-2 gap-y-2 text-sm">
        <dt><kbd>j</kbd> / <kbd>k</kbd></dt><dd class="text-ink-500">Next / previous</dd>
        <dt><kbd>↵</kbd></dt><dd class="text-ink-500">Open</dd>
        <dt><kbd>e</kbd></dt><dd class="text-ink-500">Archive</dd>
        <dt><kbd>#</kbd></dt><dd class="text-ink-500">Trash</dd>
        <dt><kbd>s</kbd></dt><dd class="text-ink-500">Star</dd>
        <dt><kbd>u</kbd></dt><dd class="text-ink-500">Mark unread</dd>
        <dt><kbd>g</kbd> <kbd>i</kbd></dt><dd class="text-ink-500">Go to inbox</dd>
        <dt><kbd>/</kbd></dt><dd class="text-ink-500">Search</dd>
        <dt><kbd>?</kbd></dt><dd class="text-ink-500">Shortcuts</dd>
      </dl>
    </div>
  </div>

  <script src="/app.js"></script>
</body>
</html>
