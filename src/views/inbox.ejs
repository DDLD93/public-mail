<%- include('partials/toolbar', { folder, q, label, domain, unread, starred, attachmentsOnly }) %>

<div class="flex-1 overflow-y-auto" x-data="mailList()" id="mailList">
  <% if (typeof notFound !== 'undefined' && notFound) { %>
    <div class="p-8 text-center text-coal-400 dark:text-coal-200 text-[13px]">404 · message not found</div>
  <% } %>

  <% if (items.length === 0) { %>
    <%- include('partials/empty') %>
  <% } else { %>
    <div>
      <% items.forEach(function(m) { %>
        <%- include('partials/mail-row', {
          mail: m,
          relativeTimeStr, initials, avatarColor, displayName, domainOf, domainColor,
          activeDomain: domain
        }) %>
      <% }); %>
    </div>

    <% if (nextCursor) { %>
      <div class="px-4 sm:px-8 py-6 text-center">
        <% const params = new URLSearchParams();
           if (folder) params.set('folder', folder);
           if (q) params.set('q', q);
           if (label) params.set('label', label);
           if (domain) params.set('domain', domain);
           if (unread) params.set('unread', '1');
           if (starred) params.set('starred', '1');
           if (attachmentsOnly) params.set('attachments', '1');
           params.set('cursor', nextCursor);
        %>
        <a href="/?<%= params.toString() %>" class="inline-flex items-center gap-2 px-4 h-9 text-[12px] uppercase tracking-wider border border-coal-900/15 dark:border-coal-50/12 hover:border-phos-500 hover:text-phos-500 transition">
          load older <i data-lucide="arrow-down" class="w-3.5 h-3.5"></i>
        </a>
      </div>
    <% } else if (items.length > 0) { %>
      <div class="px-4 sm:px-8 py-10 text-center text-coal-300 dark:text-coal-300 text-[12px] tracking-[0.2em] uppercase">[ eof ]</div>
    <% } %>
  <% } %>
</div>
