<%
const sender = displayName(mail.fromName, mail.fromAddress);
const toList = participants.filter(p => p.kind === 'to');
const ccList = participants.filter(p => p.kind === 'cc');
const bccList = participants.filter(p => p.kind === 'bcc');
const primaryTo = toList[0] || null;
const recipient = primaryTo ? displayName(primaryTo.name, primaryTo.address) : '(no recipient)';
const recipientDom = primaryTo ? domainOf(primaryTo.address) : '';
%>
<div class="sticky top-14 z-20 bg-bone-50/90 dark:bg-coal-950/90 backdrop-blur-md border-b border-coal-900/15 dark:border-coal-50/12">
  <div class="flex items-center gap-1 px-3 sm:px-6 h-12">
    <a href="javascript:history.length>1?history.back():(location.href='/')" class="iconbtn sm:btn-ghost" title="Back"><i data-lucide="arrow-left" class="w-3.5 h-3.5"></i><span class="hidden sm:inline">back</span></a>
    <div class="mx-1.5 w-px h-4 bg-coal-900/15 dark:bg-coal-50/12"></div>
    <button data-action="archive" data-id="<%= mail.id %>" class="iconbtn" title="Archive (e)"><i data-lucide="archive" class="w-3.5 h-3.5"></i></button>
    <button data-action="trash" data-id="<%= mail.id %>" class="iconbtn text-phos-600 dark:text-phos-400" title="Trash (#)"><i data-lucide="trash-2" class="w-3.5 h-3.5"></i></button>
    <button data-action="spam" data-id="<%= mail.id %>" class="iconbtn" title="Spam"><i data-lucide="shield-alert" class="w-3.5 h-3.5"></i></button>
    <div class="mx-1 w-px h-4 bg-coal-900/15 dark:bg-coal-50/12"></div>
    <button data-action="unread" data-id="<%= mail.id %>" class="iconbtn" title="Mark unread (u)"><i data-lucide="mail" class="w-3.5 h-3.5"></i></button>
    <button data-action="star" data-id="<%= mail.id %>" data-state="<%= mail.starred ? 'on' : 'off' %>" class="iconbtn" title="Star (s)">
      <i data-lucide="star" class="w-3.5 h-3.5 <%= mail.starred ? 'fill-phos-400 text-phos-400' : '' %>"></i>
    </button>
    <div class="ml-auto text-[11px] text-coal-400 dark:text-coal-200 hidden sm:block tabular-nums"><%= fullTime(mail.receivedAt) %></div>
  </div>
</div>

<div class="flex-1 overflow-y-auto">
  <article class="max-w-2xl mx-auto px-4 sm:px-8 py-8 sm:py-12">

    <div class="text-[10px] uppercase tracking-[0.2em] text-phos-600 dark:text-phos-400 mb-3 flex items-center gap-1.5">
      <span class="text-coal-300 dark:text-coal-300">&gt;</span> <%= mail.folder %> · <%= relativeTimeStr(mail.receivedAt) %>
    </div>
    <h1 class="font-sans text-[26px] sm:text-[34px] leading-[1.15] tracking-tight mb-5 break-words font-semibold"><%= mail.subject || '(no subject)' %></h1>

    <% if (mail.labels && mail.labels.length) { %>
      <div class="flex flex-wrap gap-1.5 mb-6">
        <% mail.labels.forEach(function(l) { %>
          <span class="text-[10px] uppercase tracking-wider px-2 py-1 border border-coal-900/15 dark:border-coal-50/15 text-coal-500 dark:text-coal-200">#<%= l %></span>
        <% }) %>
      </div>
    <% } %>

    <div class="pb-4 border-b border-coal-900/15 dark:border-coal-50/12">
      <div class="flex items-start gap-3.5">
        <div class="w-10 h-10 shrink-0 border border-phos-500/50 grid place-items-center text-[11px] tracking-wider text-phos-600 dark:text-phos-400">
          <%= initials(primaryTo ? primaryTo.name : null, primaryTo ? primaryTo.address : '') %>
        </div>
        <div class="min-w-0 flex-1">
          <div class="text-[10px] uppercase tracking-wider text-coal-300 dark:text-coal-300 mb-1">to</div>
          <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
            <span class="font-semibold text-[14px]"><%= recipient %></span>
            <% if (primaryTo) { %>
              <span class="text-[12px] text-coal-300 dark:text-coal-300">&lt;<%= primaryTo.address %>&gt;</span>
            <% } %>
            <% if (recipientDom) { %>
              <a href="/?domain=<%= encodeURIComponent(recipientDom) %>" title="Filter by receiver @<%= recipientDom %>"
                 class="inline-flex items-center gap-1 px-1.5 h-[18px] text-[10px] border border-coal-900/15 dark:border-coal-50/15 text-coal-400 dark:text-coal-200 hover:border-phos-500 hover:text-phos-500 transition-colors">
                <span class="w-1.5 h-1.5 <%= domainColor(recipientDom) %>"></span><%= recipientDom %>
              </a>
            <% } %>
            <% if (toList.length > 1) { %>
              <span class="text-[11px] text-coal-400 dark:text-coal-300">+<%= toList.length - 1 %> more</span>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <div x-data="{open:false}" class="flex items-start gap-3.5 py-4 border-b border-coal-900/15 dark:border-coal-50/12">
      <div class="w-10 h-10 shrink-0 border border-coal-900/15 dark:border-coal-50/15 grid place-items-center text-[11px] tracking-wider text-coal-500 dark:text-coal-300">
        <%= initials(mail.fromName, mail.fromAddress) %>
      </div>
      <div class="min-w-0 flex-1">
        <div class="text-[10px] uppercase tracking-wider text-coal-300 dark:text-coal-300 mb-1">from</div>
        <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
          <span class="font-semibold text-[14px]"><%= sender %></span>
          <span class="text-[12px] text-coal-300 dark:text-coal-300">&lt;<%= mail.fromAddress %>&gt;</span>
        </div>
        <button @click="open = !open" class="text-[12px] text-coal-400 dark:text-coal-200 hover:text-phos-600 dark:hover:text-phos-400 inline-flex items-center gap-1 mt-2 transition-colors">
          <span x-text="open ? '[-] hide headers' : '[+] show headers'"></span>
        </button>
        <div x-show="open" x-transition class="mt-3 text-[12px] space-y-1.5 text-coal-500 dark:text-coal-200" style="display:none">
          <% if (toList.length) { %><div><span class="text-coal-300 dark:text-coal-300 uppercase tracking-wider text-[10px] mr-2">to</span><%= toList.map(p => displayName(p.name, p.address) + ' <' + p.address + '>').join(', ') %></div><% } %>
          <% if (ccList.length) { %><div><span class="text-coal-300 dark:text-coal-300 uppercase tracking-wider text-[10px] mr-2">cc</span><%= ccList.map(p => displayName(p.name, p.address) + ' <' + p.address + '>').join(', ') %></div><% } %>
          <% if (bccList.length) { %><div><span class="text-coal-300 dark:text-coal-300 uppercase tracking-wider text-[10px] mr-2">bcc</span><%= bccList.map(p => displayName(p.name, p.address) + ' <' + p.address + '>').join(', ') %></div><% } %>
          <% if (mail.replyTo) { %><div><span class="text-coal-300 dark:text-coal-300 uppercase tracking-wider text-[10px] mr-2">reply-to</span><%= mail.replyTo %></div><% } %>
          <div><span class="text-coal-300 dark:text-coal-300 uppercase tracking-wider text-[10px] mr-2">received</span><%= fullTime(mail.receivedAt) %></div>
          <div class="text-[11px] break-all"><span class="text-coal-300 dark:text-coal-300 uppercase tracking-wider text-[10px] mr-2">id</span><%= mail.messageId %></div>
        </div>
      </div>
    </div>

    <!-- Body -->
    <div class="mt-8 prose-mail">
      <% if (mailFrameSrcdoc) { %>
        <iframe id="mailFrame" sandbox="allow-same-origin allow-popups allow-popups-to-escape-sandbox"
                srcdoc="<%= mailFrameSrcdoc %>"
                class="w-full block bg-transparent border-0" style="height: 60vh; min-height: 320px;"></iframe>
      <% } else if (mail.text) { %>
        <pre class="whitespace-pre-wrap break-words font-sans text-[15px] leading-relaxed text-coal-700 dark:text-coal-100"><%= mail.text %></pre>
      <% } else { %>
        <div class="text-coal-300 dark:text-coal-300 italic">(empty body)</div>
      <% } %>
    </div>

    <!-- Attachments -->
    <% if (attachments && attachments.length) { %>
      <div class="mt-10 pt-6 border-t border-coal-900/15 dark:border-coal-50/12">
        <div class="text-[10px] uppercase tracking-[0.2em] text-coal-400 dark:text-coal-300 mb-3">
          <%= attachments.length %> file<%= attachments.length === 1 ? '' : 's' %> attached
        </div>
        <div class="space-y-1.5">
          <% attachments.forEach(function(a) {
            const mt = (a.mimeType || '').toLowerCase();
            let icon = 'file';
            if (mt.includes('pdf')) icon = 'file-text';
            else if (mt.startsWith('image/')) icon = 'image';
            else if (mt.startsWith('video/')) icon = 'film';
            else if (mt.startsWith('audio/')) icon = 'music';
            else if (mt.includes('zip') || mt.includes('rar') || mt.includes('tar')) icon = 'file-archive';
            else if (mt.includes('sheet') || mt.includes('excel')) icon = 'file-spreadsheet';
            else if (mt.includes('word') || mt.includes('document')) icon = 'file-text';
          %>
            <a href="/attachments/<%= a.id %>" class="group flex items-center gap-3 p-2.5 border border-coal-900/12 dark:border-coal-50/[0.08] hover:border-phos-500 dark:hover:border-phos-500 hover:bg-phos-500/[0.05] transition">
              <span class="w-9 h-9 border border-coal-900/15 dark:border-coal-50/15 grid place-items-center text-coal-500 dark:text-coal-200 group-hover:text-phos-600 dark:group-hover:text-phos-400 transition-colors">
                <i data-lucide="<%= icon %>" class="w-4 h-4"></i>
              </span>
              <div class="min-w-0 flex-1">
                <div class="truncate text-[13px] text-coal-800 dark:text-coal-50 font-sans"><%= a.filename || 'attachment' %></div>
                <div class="text-[11px] text-coal-400 dark:text-coal-300"><%= a.mimeType || 'application/octet-stream' %> · <%= fmtBytes(a.sizeBytes) %></div>
              </div>
              <i data-lucide="download" class="w-3.5 h-3.5 text-coal-300 dark:text-coal-300 group-hover:text-phos-600 dark:group-hover:text-phos-400 transition-colors"></i>
            </a>
          <% }) %>
        </div>
      </div>
    <% } %>

    <div class="mt-14 text-center text-coal-300 dark:text-coal-300 text-[11px] tracking-[0.2em] uppercase">[ eof ]</div>
  </article>
</div>

<script>
  (function() {
    const f = document.getElementById('mailFrame');
    if (!f) return;
    f.addEventListener('load', function() {
      try {
        const doc = f.contentDocument;
        if (!doc) return;
        const resize = () => {
          const h = Math.max(doc.body.scrollHeight, doc.documentElement.scrollHeight);
          f.style.height = (h + 16) + 'px';
        };
        resize();
        new ResizeObserver(resize).observe(doc.body);
      } catch (e) {}
    });
  })();
</script>
