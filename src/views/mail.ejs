<%
const sender = displayName(mail.fromName, mail.fromAddress);
const toList = participants.filter(p => p.kind === 'to');
const ccList = participants.filter(p => p.kind === 'cc');
const bccList = participants.filter(p => p.kind === 'bcc');
%>
<div class="sticky top-16 z-20 bg-paper-50/85 dark:bg-ink-950/85 backdrop-blur-md border-b border-ink-200/40 dark:border-ink-700/40">
  <div class="flex items-center gap-1 px-4 sm:px-8 h-12">
    <a href="javascript:history.length>1?history.back():(location.href='/')" class="btn-ghost"><i data-lucide="arrow-left" class="w-3.5 h-3.5"></i><span class="hidden sm:inline">Back</span></a>
    <div class="mx-2 w-px h-4 bg-ink-200 dark:bg-ink-700"></div>
    <button data-action="archive" data-id="<%= mail.id %>" class="btn-ghost" title="Archive (e)"><i data-lucide="archive" class="w-3.5 h-3.5"></i></button>
    <button data-action="trash" data-id="<%= mail.id %>" class="btn-ghost text-sienna-600 dark:text-sienna-300" title="Trash (#)"><i data-lucide="trash-2" class="w-3.5 h-3.5"></i></button>
    <button data-action="spam" data-id="<%= mail.id %>" class="btn-ghost" title="Spam"><i data-lucide="shield-alert" class="w-3.5 h-3.5"></i></button>
    <div class="mx-1 w-px h-4 bg-ink-200 dark:bg-ink-700"></div>
    <button data-action="unread" data-id="<%= mail.id %>" class="btn-ghost" title="Mark unread (u)"><i data-lucide="mail" class="w-3.5 h-3.5"></i></button>
    <button data-action="star" data-id="<%= mail.id %>" data-state="<%= mail.starred ? 'on' : 'off' %>" class="btn-ghost" title="Star (s)">
      <i data-lucide="star" class="w-3.5 h-3.5 <%= mail.starred ? 'fill-sienna-500 text-sienna-500' : '' %>"></i>
    </button>
    <div class="ml-auto text-[11px] text-ink-400 dark:text-ink-500 hidden sm:block font-mono tabular-nums"><%= fullTime(mail.receivedAt) %></div>
  </div>
</div>

<div class="flex-1 overflow-y-auto">
  <article class="max-w-2xl mx-auto px-4 sm:px-8 py-10 sm:py-14">

    <div class="text-[10px] uppercase tracking-[0.18em] text-ink-400 dark:text-ink-500 mb-3"><%= mail.folder %> · <%= relativeTimeStr(mail.receivedAt) %></div>
    <h1 class="font-serif text-[32px] sm:text-[44px] leading-[1.1] tracking-tight mb-5 break-words"><%= mail.subject || '(no subject)' %></h1>

    <% if (mail.labels && mail.labels.length) { %>
      <div class="flex flex-wrap gap-1.5 mb-6">
        <% mail.labels.forEach(function(l) { %>
          <span class="text-[10px] uppercase tracking-wider px-2 py-1 rounded-sm border border-ink-200 dark:border-ink-700 text-ink-500 dark:text-ink-400"><%= l %></span>
        <% }) %>
      </div>
    <% } %>

    <div x-data="{open:false}" class="flex items-start gap-4 pb-6 border-b border-ink-200/60 dark:border-ink-700/40">
      <div class="w-10 h-10 shrink-0 rounded-full border border-ink-300 dark:border-ink-600 grid place-items-center font-mono text-[11px] tracking-wider text-ink-700 dark:text-ink-200">
        <%= initials(mail.fromName, mail.fromAddress) %>
      </div>
      <div class="min-w-0 flex-1">
        <div class="flex flex-wrap items-baseline gap-x-2 gap-y-0.5">
          <span class="font-medium text-[15px]"><%= sender %></span>
          <span class="text-[13px] text-ink-400 font-mono">&lt;<%= mail.fromAddress %>&gt;</span>
        </div>
        <button @click="open = !open" class="text-[12px] text-ink-400 hover:text-sienna-600 dark:hover:text-sienna-300 inline-flex items-center gap-1 mt-1 transition-colors">
          <span x-text="open ? 'Hide details' : 'Show details'"></span>
          <i :data-lucide="open ? 'chevron-up' : 'chevron-down'" class="w-3 h-3"></i>
        </button>
        <div x-show="open" x-transition class="mt-3 text-[13px] space-y-1.5 text-ink-500 dark:text-ink-400" style="display:none">
          <% if (toList.length) { %><div><span class="text-ink-300 dark:text-ink-500 uppercase tracking-wider text-[10px] mr-2">to</span><%= toList.map(p => displayName(p.name, p.address) + ' <' + p.address + '>').join(', ') %></div><% } %>
          <% if (ccList.length) { %><div><span class="text-ink-300 dark:text-ink-500 uppercase tracking-wider text-[10px] mr-2">cc</span><%= ccList.map(p => displayName(p.name, p.address) + ' <' + p.address + '>').join(', ') %></div><% } %>
          <% if (bccList.length) { %><div><span class="text-ink-300 dark:text-ink-500 uppercase tracking-wider text-[10px] mr-2">bcc</span><%= bccList.map(p => displayName(p.name, p.address) + ' <' + p.address + '>').join(', ') %></div><% } %>
          <% if (mail.replyTo) { %><div><span class="text-ink-300 dark:text-ink-500 uppercase tracking-wider text-[10px] mr-2">reply-to</span><%= mail.replyTo %></div><% } %>
          <div><span class="text-ink-300 dark:text-ink-500 uppercase tracking-wider text-[10px] mr-2">received</span><%= fullTime(mail.receivedAt) %></div>
          <div class="font-mono text-[11px] break-all"><span class="text-ink-300 dark:text-ink-500 uppercase tracking-wider text-[10px] mr-2 font-sans">id</span><%= mail.messageId %></div>
        </div>
      </div>
    </div>

    <!-- Body -->
    <div class="mt-8 prose-mail">
      <% if (mail.html) { %>
        <iframe id="mailFrame" sandbox="allow-popups allow-popups-to-escape-sandbox"
                srcdoc="<%= escapeHtml(`<!doctype html><html><head><meta charset='utf-8'><base target='_blank'><style>html,body{margin:0;padding:0;font-family:Inter,system-ui,sans-serif;color:#1c1814;line-height:1.7;font-size:15px;word-wrap:break-word;background:transparent}@media (prefers-color-scheme: dark){html,body{color:#e6e1d4}}a{color:#a85f30;text-decoration:underline;text-underline-offset:2px}img{max-width:100%;height:auto;border-radius:4px}table{max-width:100%}blockquote{border-left:2px solid #d8c9b0;padding-left:1em;margin-left:0;color:#5b554a;font-style:italic}h1,h2,h3{font-family:Fraunces,Georgia,serif;letter-spacing:-0.01em}</style></head><body>${sanitizedHtml}</body></html>`) %>"
                class="w-full block bg-transparent" style="height: 60vh; min-height: 320px;"></iframe>
      <% } else if (mail.text) { %>
        <pre class="whitespace-pre-wrap break-words font-sans text-[15px] leading-relaxed text-ink-700 dark:text-ink-200"><%= mail.text %></pre>
      <% } else { %>
        <div class="text-ink-300 dark:text-ink-600 italic font-serif">(empty body)</div>
      <% } %>
    </div>

    <!-- Attachments -->
    <% if (attachments && attachments.length) { %>
      <div class="mt-10 pt-6 border-t border-ink-200/60 dark:border-ink-700/40">
        <div class="text-[10px] uppercase tracking-[0.18em] text-ink-400 dark:text-ink-500 mb-3">
          <%= attachments.length %> attachment<%= attachments.length === 1 ? '' : 's' %>
        </div>
        <div class="space-y-2">
          <% attachments.forEach(function(a) {
            const mt = (a.mimeType || '').toLowerCase();
            let icon = 'file';
            if (mt.includes('pdf')) icon = 'file-text';
            else if (mt.startsWith('image/')) icon = 'image';
            else if (mt.startsWith('video/')) icon = 'film';
            else if (mt.startsWith('audio/')) icon = 'music';
            else if (mt.includes('zip') || mt.includes('rar') || mt.includes('tar')) icon = 'file-archive';
            else if (mt.includes('sheet') || mt.includes('excel')) icon = 'file-spreadsheet';
            else if (mt.includes('word') || mt.includes('document')) icon = 'file-text';
          %>
            <a href="/attachments/<%= a.id %>" class="group flex items-center gap-3 p-3 rounded-md border border-ink-200/60 dark:border-ink-700/60 hover:border-ink-400 dark:hover:border-ink-500 hover:bg-paper-100/50 dark:hover:bg-ink-900/50 transition">
              <span class="w-9 h-9 rounded-md border border-ink-200 dark:border-ink-700 grid place-items-center text-ink-500 dark:text-ink-400 group-hover:text-sienna-600 dark:group-hover:text-sienna-300 transition-colors">
                <i data-lucide="<%= icon %>" class="w-4 h-4"></i>
              </span>
              <div class="min-w-0 flex-1">
                <div class="truncate text-[14px] text-ink-800 dark:text-ink-100"><%= a.filename || 'attachment' %></div>
                <div class="text-[11px] font-mono text-ink-400 dark:text-ink-500"><%= a.mimeType || 'application/octet-stream' %> · <%= fmtBytes(a.sizeBytes) %></div>
              </div>
              <i data-lucide="arrow-down" class="w-3.5 h-3.5 text-ink-300 dark:text-ink-500 group-hover:text-sienna-600 dark:group-hover:text-sienna-300 transition-colors"></i>
            </a>
          <% }) %>
        </div>
      </div>
    <% } %>

    <div class="mt-14 text-center font-serif italic text-ink-300 dark:text-ink-600">⁂</div>
  </article>
</div>

<script>
  (function() {
    const f = document.getElementById('mailFrame');
    if (!f) return;
    f.addEventListener('load', function() {
      try {
        const doc = f.contentDocument;
        if (!doc) return;
        const resize = () => {
          const h = Math.max(doc.body.scrollHeight, doc.documentElement.scrollHeight);
          f.style.height = (h + 16) + 'px';
        };
        resize();
        new ResizeObserver(resize).observe(doc.body);
      } catch (e) {}
    });
  })();
</script>
