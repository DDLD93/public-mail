<%
const folderMeta = {
  inbox:   { label: 'inbox',   icon: 'inbox' },
  archive: { label: 'archive', icon: 'archive' },
  spam:    { label: 'spam',    icon: 'shield-alert' },
  trash:   { label: 'trash',   icon: 'trash-2' },
};
function isActive(name) { return folder === name && !label; }
%>
<div class="flex-1 overflow-y-auto px-3 sm:px-4 py-5 space-y-6 flex flex-col">

  <div class="px-1.5">
    <div class="text-[10px] uppercase tracking-[0.22em] text-phos-600 dark:text-phos-400 mb-1 flex items-center gap-1.5">
      <span class="w-1 h-1 bg-phos-400"></span> mailroom
    </div>
    <div class="text-[12px] text-coal-400 dark:text-coal-200">~/recently-delivered</div>
  </div>

  <nav class="space-y-px">
    <% for (const f of systemFolders) {
         const meta = folderMeta[f];
         const c = (sidebar.counts && sidebar.counts[f]) || { unread: 0, total: 0 };
         const active = isActive(f);
    %>
      <a href="/?folder=<%= f %>"
         class="sb-row <%= active ? 'sb-row-active' : '' %>">
        <span class="flex items-center gap-2.5 min-w-0">
          <i data-lucide="<%= meta.icon %>" class="w-[15px] h-[15px] opacity-70"></i>
          <span class="truncate"><%= meta.label %></span>
        </span>
        <% if (c.unread > 0) { %>
          <span class="text-[11px] tabular-nums text-phos-600 dark:text-phos-400 font-semibold"><%= c.unread %></span>
        <% } else if (c.total > 0 && f !== 'inbox') { %>
          <span class="text-[11px] tabular-nums text-coal-300 dark:text-coal-300"><%= c.total %></span>
        <% } %>
      </a>
    <% } %>

    <a href="/?starred=1" class="sb-row">
      <span class="flex items-center gap-2.5">
        <i data-lucide="star" class="w-[15px] h-[15px] opacity-70"></i>
        <span>starred</span>
      </span>
      <% if (sidebar.starred > 0) { %>
        <span class="text-[11px] tabular-nums text-coal-300 dark:text-coal-300"><%= sidebar.starred %></span>
      <% } %>
    </a>
  </nav>

  <div>
    <div class="px-1.5 mb-1.5 text-[10px] uppercase tracking-[0.22em] text-coal-400 dark:text-coal-300">labels/</div>
    <div class="space-y-px">
      <% (sidebar.labels || []).forEach(function(l, i) {
           const dotColors = ['bg-phos-400','bg-emerald-400','bg-sky-400','bg-violet-400','bg-rose-400','bg-amber-400'];
           const dot = dotColors[i % dotColors.length];
      %>
        <a href="/?label=<%= encodeURIComponent(l.label) %>"
           class="sb-row <%= label === l.label ? 'sb-row-active' : '' %>">
          <span class="flex items-center gap-2.5 truncate">
            <span class="text-coal-300 dark:text-coal-300">#</span>
            <span class="w-1.5 h-1.5 <%= dot %>"></span>
            <span class="truncate"><%= l.label %></span>
          </span>
          <% if (l.unread > 0) { %>
            <span class="text-[11px] tabular-nums text-phos-600 dark:text-phos-400 font-semibold"><%= l.unread %></span>
          <% } %>
        </a>
      <% }); %>
      <% if (!sidebar.labels || sidebar.labels.length === 0) { %>
        <div class="px-1.5 text-[12px] text-coal-300 dark:text-coal-300">— none —</div>
      <% } %>
    </div>
  </div>

  <div>
    <div class="px-1.5 mb-1.5 text-[10px] uppercase tracking-[0.22em] text-coal-400 dark:text-coal-300 flex items-center justify-between">
      <span>domains/</span>
      <% if (typeof domain !== 'undefined' && domain) { %>
        <a href="/?folder=<%= folder || 'inbox' %>" class="text-phos-600 dark:text-phos-400 normal-case tracking-normal hover:underline">clear</a>
      <% } %>
    </div>
    <div class="space-y-px">
      <% (sidebar.domains || []).forEach(function(d) {
           const active = (typeof domain !== 'undefined' && domain) && domain.toLowerCase() === d.domain;
      %>
        <a href="/?domain=<%= encodeURIComponent(d.domain) %>"
           class="sb-row <%= active ? 'sb-row-active' : '' %>" title="@<%= d.domain %>">
          <span class="flex items-center gap-2.5 truncate">
            <span class="text-coal-300 dark:text-coal-300">@</span>
            <span class="w-1.5 h-1.5 <%= domainColor(d.domain) %>"></span>
            <span class="truncate"><%= d.domain %></span>
          </span>
          <% if (d.unread > 0) { %>
            <span class="text-[11px] tabular-nums text-phos-600 dark:text-phos-400 font-semibold"><%= d.unread %></span>
          <% } else { %>
            <span class="text-[11px] tabular-nums text-coal-300 dark:text-coal-300"><%= d.total %></span>
          <% } %>
        </a>
      <% }); %>
      <% if (!sidebar.domains || sidebar.domains.length === 0) { %>
        <div class="px-1.5 text-[12px] text-coal-300 dark:text-coal-300">— none —</div>
      <% } %>
    </div>
  </div>

  <div class="mt-auto pt-5 border-t border-coal-900/15 dark:border-coal-50/12">
    <div class="px-1.5">
      <div class="text-[10px] uppercase tracking-[0.22em] text-coal-400 dark:text-coal-300 mb-1.5">endpoint</div>
      <code class="block text-[11px] text-phos-600 dark:text-phos-400 break-all">
        <span class="text-coal-300 dark:text-coal-300">$</span> POST /webhook/mail
      </code>
    </div>
  </div>
</div>
