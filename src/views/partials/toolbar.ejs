<div class="sticky top-14 z-20 bg-bone-50/90 dark:bg-coal-950/90 backdrop-blur-md border-b border-coal-900/15 dark:border-coal-50/12">
  <div class="flex items-end gap-4 px-3 sm:px-6 pt-4 pb-3">
    <div class="min-w-0">
      <div class="text-[10px] uppercase tracking-[0.22em] text-coal-400 dark:text-coal-300 flex items-center gap-1.5">
        <span class="text-phos-500">&gt;</span>
        <%= q ? 'search' : (label ? 'label' : (starred ? 'filter' : 'folder')) %>
      </div>
      <h1 class="text-[20px] sm:text-[24px] leading-none tracking-tight mt-1.5 font-semibold lowercase truncate">
        <% if (label) { %>
          #<%= label %>
        <% } else if (starred) { %>
          starred
        <% } else { %>
          <%= folder %>
        <% } %>
      </h1>
    </div>
    <div class="ml-auto hidden lg:flex items-center gap-1 text-[10px] text-coal-300 dark:text-coal-200 tabular-nums pb-0.5">
      <span x-text="refreshLabel"></span>
    </div>
  </div>

  <div class="flex items-center gap-1.5 px-3 sm:px-6 pb-2.5 overflow-x-auto no-scrollbar">
    <% function chipUrl(key, val) {
      const params = new URLSearchParams();
      if (folder) params.set('folder', folder);
      if (q) params.set('q', q);
      if (label) params.set('label', label);
      if (unread && key !== 'unread') params.set('unread', '1');
      if (starred && key !== 'starred') params.set('starred', '1');
      if (attachmentsOnly && key !== 'attachments') params.set('attachments', '1');
      if (val) params.set(key, '1');
      return '/?' + params.toString();
    } %>
    <a href="<%= chipUrl('unread', !unread) %>" class="chip <%= unread ? 'chip-on' : '' %>" title="Unread">
      <i data-lucide="mail" class="w-3.5 h-3.5"></i> <span class="hidden sm:inline">unread</span>
    </a>
    <a href="<%= chipUrl('starred', !starred) %>" class="chip <%= starred ? 'chip-on' : '' %>" title="Starred">
      <i data-lucide="star" class="w-3.5 h-3.5"></i> <span class="hidden sm:inline">starred</span>
    </a>
    <a href="<%= chipUrl('attachments', !attachmentsOnly) %>" class="chip <%= attachmentsOnly ? 'chip-on' : '' %>" title="With files">
      <i data-lucide="paperclip" class="w-3.5 h-3.5"></i> <span class="hidden sm:inline">files</span>
    </a>
    <div class="ml-auto lg:hidden text-[10px] text-coal-300 dark:text-coal-200 tabular-nums self-center" x-text="refreshLabel"></div>
  </div>

  <!-- Bulk actions bar -->
  <div x-show="selected.length > 0" x-transition class="flex items-center gap-2 px-3 sm:px-6 h-12 border-t border-coal-900/15 dark:border-coal-50/12 bg-phos-500/[0.06]">
    <span class="text-[12px] flex items-center gap-1.5"><span class="text-phos-600 dark:text-phos-400 font-semibold tabular-nums" x-text="selected.length"></span> <span class="text-coal-400 dark:text-coal-200 uppercase tracking-wider text-[11px]">sel</span></span>
    <div class="ml-auto flex items-center gap-0.5">
      <button @click="bulk('read')" class="iconbtn" title="Mark read"><i data-lucide="mail-open" class="w-3.5 h-3.5"></i></button>
      <button @click="bulk('unread')" class="iconbtn" title="Mark unread"><i data-lucide="mail" class="w-3.5 h-3.5"></i></button>
      <button @click="bulk('star')" class="iconbtn" title="Star"><i data-lucide="star" class="w-3.5 h-3.5"></i></button>
      <button @click="bulk('archive')" class="iconbtn" title="Archive"><i data-lucide="archive" class="w-3.5 h-3.5"></i></button>
      <button @click="bulk('trash')" class="iconbtn text-phos-600 dark:text-phos-400" title="Trash"><i data-lucide="trash-2" class="w-3.5 h-3.5"></i></button>
      <span class="mx-0.5 w-px h-4 bg-coal-900/15 dark:bg-coal-50/12"></span>
      <button @click="clearSelect()" class="iconbtn" title="Clear"><i data-lucide="x" class="w-3.5 h-3.5"></i></button>
    </div>
  </div>
</div>
