<div class="sticky top-16 z-20 bg-paper-50/85 dark:bg-ink-950/85 backdrop-blur-md border-b border-ink-200/40 dark:border-ink-700/40">
  <div class="flex items-end gap-4 px-4 sm:px-8 pt-6 pb-4">
    <div>
      <div class="text-[10px] uppercase tracking-[0.18em] text-ink-400 dark:text-ink-500"><%= q ? 'Search results' : (label ? 'Label' : (starred ? 'Filter' : 'Folder')) %></div>
      <h1 class="font-serif text-[28px] sm:text-[34px] leading-none tracking-tight mt-1.5">
        <% if (label) { %>
          <%= label %>
        <% } else if (starred) { %>
          <span class="italic">Starred</span>
        <% } else { %>
          <span class="capitalize"><%= folder %></span>
        <% } %>
      </h1>
    </div>
    <div class="ml-auto hidden sm:flex items-center gap-1 text-[11px] text-ink-400 dark:text-ink-500 font-mono tabular-nums pb-1">
      <span x-text="refreshLabel"></span>
    </div>
  </div>

  <div class="flex items-center gap-1.5 px-4 sm:px-8 pb-3 overflow-x-auto no-scrollbar">
    <% function chipUrl(key, val) {
      const params = new URLSearchParams();
      if (folder) params.set('folder', folder);
      if (q) params.set('q', q);
      if (label) params.set('label', label);
      if (unread && key !== 'unread') params.set('unread', '1');
      if (starred && key !== 'starred') params.set('starred', '1');
      if (attachmentsOnly && key !== 'attachments') params.set('attachments', '1');
      if (val) params.set(key, '1');
      return '/?' + params.toString();
    } %>
    <a href="<%= chipUrl('unread', !unread) %>" class="chip <%= unread ? 'chip-on' : '' %>">
      <span class="w-1 h-1 rounded-full bg-current opacity-70"></span> Unread
    </a>
    <a href="<%= chipUrl('starred', !starred) %>" class="chip <%= starred ? 'chip-on' : '' %>">
      <i data-lucide="star" class="w-3 h-3"></i> Starred
    </a>
    <a href="<%= chipUrl('attachments', !attachmentsOnly) %>" class="chip <%= attachmentsOnly ? 'chip-on' : '' %>">
      <i data-lucide="paperclip" class="w-3 h-3"></i> With files
    </a>
    <div class="ml-auto sm:hidden text-[10px] text-ink-400 dark:text-ink-500 font-mono tabular-nums" x-text="refreshLabel"></div>
  </div>

  <!-- Bulk actions bar -->
  <div x-show="selected.length > 0" x-transition class="flex items-center gap-2 px-4 sm:px-8 h-12 border-t border-ink-200/40 dark:border-ink-700/40 bg-paper-100/60 dark:bg-ink-900/60">
    <span class="text-[13px]"><span class="font-medium" x-text="selected.length"></span> <span class="text-ink-400">selected</span></span>
    <div class="ml-auto flex items-center gap-0.5">
      <button @click="bulk('read')" class="btn-ghost"><i data-lucide="mail-open" class="w-3.5 h-3.5"></i> Read</button>
      <button @click="bulk('unread')" class="btn-ghost"><i data-lucide="mail" class="w-3.5 h-3.5"></i> Unread</button>
      <button @click="bulk('star')" class="btn-ghost"><i data-lucide="star" class="w-3.5 h-3.5"></i></button>
      <button @click="bulk('archive')" class="btn-ghost"><i data-lucide="archive" class="w-3.5 h-3.5"></i></button>
      <button @click="bulk('trash')" class="btn-ghost text-sienna-600 dark:text-sienna-300"><i data-lucide="trash-2" class="w-3.5 h-3.5"></i></button>
      <button @click="clearSelect()" class="btn-ghost"><i data-lucide="x" class="w-3.5 h-3.5"></i></button>
    </div>
  </div>
</div>
