<div class="flex-1 grid place-items-center p-8">
  <div class="text-center max-w-md">
    <div class="mx-auto w-24 h-24 rounded-3xl bg-gradient-to-br from-brand-400 to-brand-700 text-white grid place-items-center shadow-glow mb-5">
      <i data-lucide="mail-plus" class="w-10 h-10"></i>
    </div>
    <h2 class="text-xl font-semibold mb-2">Your mailbox is squeaky clean</h2>
    <p class="text-ink-500 mb-5">When mail arrives via your webhook, it shows up here. Try sending a test event:</p>
    <pre class="text-left text-xs bg-ink-100 dark:bg-ink-900/70 p-3 rounded-xl overflow-x-auto"><code>curl -X POST http://localhost:<%= process.env.PORT || 3000 %>/webhook/mail \
  -H "Content-Type: application/json" \
  -H "X-Webhook-Secret: $WEBHOOK_SECRET" \
  -d @sample-payload.json</code></pre>
  </div>
</div>
