<div class="flex-1 grid place-items-center p-6">
  <div class="text-center max-w-md w-full">
    <div class="mx-auto mb-5 w-12 h-12 border border-phos-500/60 grid place-items-center text-phos-500">
      <i data-lucide="inbox" class="w-5 h-5"></i>
    </div>
    <h2 class="text-[18px] tracking-tight mb-1.5 font-semibold lowercase">0 messages · queue empty</h2>
    <p class="text-coal-400 dark:text-coal-200 mb-6 text-[13px]">stdin idle — waiting on POST /webhook/mail</p>
    <div class="text-left bg-coal-950 border border-phos-500/40 p-4">
      <div class="text-[10px] uppercase tracking-[0.2em] text-phos-400 mb-2 flex items-center gap-1.5">
        <i data-lucide="terminal" class="w-3 h-3"></i> test it
      </div>
      <pre class="text-[11px] text-coal-50 overflow-x-auto leading-relaxed"><code><span class="text-phos-400">$</span> curl -X POST http://localhost:<%= process.env.PORT || 3000 %>/webhook/mail \
    -H <span class="text-phos-300">"Content-Type: application/json"</span> \
    -H <span class="text-phos-300">"Authorization: Bearer $INCOMING_API_BEARER"</span> \
    -d @sample-payload.json</code></pre>
    </div>
  </div>
</div>
