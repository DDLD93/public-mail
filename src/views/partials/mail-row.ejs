<%
const m = mail;
const isUnread = m.status === 'unread';
const sender = displayName(m.fromName, m.fromAddress);
const initialsStr = initials(m.fromName, m.fromAddress);
%>
<a href="/mail/<%= m.id %>" data-mail-id="<%= m.id %>"
   class="mail-row group relative grid grid-cols-[auto_auto_auto_1fr_auto] items-center gap-3 sm:gap-4 px-4 sm:px-8 py-4 border-b border-ink-200/40 dark:border-ink-700/40 hover:bg-paper-100/60 dark:hover:bg-ink-900/40 transition-colors">
  <% if (isUnread) { %>
    <span class="absolute left-0 top-0 bottom-0 w-[2px] bg-sienna-500"></span>
  <% } %>

  <input type="checkbox" data-mail-check value="<%= m.id %>" @click.stop="toggleSelect('<%= m.id %>')"
         class="shrink-0 w-3.5 h-3.5 rounded-sm border-ink-300 dark:border-ink-600 text-ink-700 dark:text-ink-200 focus:ring-1 focus:ring-ink-400 bg-transparent"/>

  <button type="button" data-action="star" data-id="<%= m.id %>" data-state="<%= m.starred ? 'on' : 'off' %>"
          class="shrink-0 p-1 -m-1 rounded-sm" aria-label="Star">
    <i data-lucide="star" class="w-3.5 h-3.5 <%= m.starred ? 'fill-sienna-500 text-sienna-500' : 'text-ink-200 dark:text-ink-600 hover:text-sienna-400' %>"></i>
  </button>

  <div class="w-8 h-8 shrink-0 rounded-full border <%= isUnread ? 'border-ink-800 dark:border-ink-100 bg-paper-100 dark:bg-ink-800' : 'border-ink-200 dark:border-ink-700 bg-transparent' %> grid place-items-center text-[10px] font-medium font-mono tracking-wider <%= isUnread ? 'text-ink-800 dark:text-ink-100' : 'text-ink-400 dark:text-ink-500' %>">
    <%= initialsStr %>
  </div>

  <div class="min-w-0">
    <div class="flex items-baseline gap-2 mb-0.5">
      <span class="truncate text-[14px] <%= isUnread ? 'font-semibold text-ink-900 dark:text-ink-50' : 'text-ink-500 dark:text-ink-300' %>"><%= sender %></span>
      <% if (m.labels && m.labels.length) { %>
        <% m.labels.slice(0,2).forEach(function(l) { %>
          <span class="hidden sm:inline-flex text-[10px] uppercase tracking-wider px-1.5 py-0.5 rounded-sm border border-ink-200 dark:border-ink-700 text-ink-500 dark:text-ink-400"><%= l %></span>
        <% }) %>
      <% } %>
    </div>
    <div class="flex items-center gap-1.5 mb-0.5">
      <span class="font-serif text-[16px] leading-snug truncate <%= isUnread ? 'text-ink-900 dark:text-ink-50' : 'text-ink-600 dark:text-ink-300' %>"><%= m.subject || '(no subject)' %></span>
      <% if (m.hasAttachments) { %>
        <i data-lucide="paperclip" class="w-3 h-3 text-ink-300 dark:text-ink-500 shrink-0"></i>
      <% } %>
    </div>
    <div class="truncate text-[13px] text-ink-400 dark:text-ink-500"><%= m.snippet || '' %></div>
  </div>

  <div class="text-[11px] text-ink-400 dark:text-ink-500 font-mono tabular-nums shrink-0 self-start pt-0.5"><%= relativeTimeStr(m.receivedAt) %></div>
</a>
